{
  "name": "clsniff",
  "version": "1.0.3",
  "description": "Zero-configuration HTTP/HTTPS traffic sniffer for command-line tools like claude",
  "bin": {
    "clsniff": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "http",
    "proxy",
    "mitm",
    "logger",
    "traffic",
    "intercept",
    "claude",
    "anthropic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/panicoenlaxbox/clsniff.git"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "http-mitm-proxy": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
