{
  "name": "clsniff",
  "version": "1.3.4",
  "description": "Zero-configuration HTTP/HTTPS traffic sniffer for command-line tools like claude",
  "bin": {
    "clsniff": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/",
    "logger.py",
    "viewer/dist/"
  ],
  "scripts": {
    "build": "npm run build:viewer && tsc",
    "build:viewer": "cd viewer && npm install && npm run build",
    "dev": "tsx src/cli.ts",
    "dev:hot": "concurrently -n api,vite -c blue,green \"cross-env CLSNIFF_SERVER_PORT=3747 tsx src/cli.ts --viewer --no-open\" \"cd viewer && npm run dev -- --open\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "http",
    "proxy",
    "mitm",
    "mitmproxy",
    "mitmdump",
    "logger",
    "traffic",
    "intercept",
    "claude",
    "anthropic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/panicoenlaxbox/clsniff.git"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
